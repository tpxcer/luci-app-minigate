msgstr "动态DNS"

msgid "SSL Certificate"
msgstr "SSL 证书"

msgid "Reverse Proxy"
msgstr "反向代理"

msgid "Logs"
msgstr "日志"

msgid "MiniGate - DDNS"
msgstr "MiniGate - 动态DNS"

msgid "Configure Dynamic DNS with Cloudflare. Automatically updates your DNS record when your WAN IP changes."
msgstr "配置 Cloudflare 动态域名解析。当 WAN 口 IP 变化时自动更新 DNS 记录。"

msgid "DDNS Settings"
msgstr "DDNS 设置"

msgid "Enable DDNS"
msgstr "启用 DDNS"

msgid "DNS Provider"
msgstr "DNS 服务商"

msgid "Domain"
msgstr "域名"

msgid "Cloudflare Zone ID"
msgstr "Cloudflare 区域 ID"

msgid "Enter your Zone ID from Cloudflare dashboard"
msgstr "在 Cloudflare 控制台获取区域 ID"

msgid "Cloudflare API Token"
msgstr "Cloudflare API 令牌"

msgid "Enter your API Token"
msgstr "输入你的 API 令牌"

msgid "IP Source"
msgstr "IP 获取方式"

msgid "Network Interface"
msgstr "网络接口"

msgid "External URL"
msgstr "外部接口（URL）"

msgid "WAN Interface"
msgstr "WAN 接口"

msgid "Check Interval (seconds)"
msgstr "检查间隔（秒）"

msgid "Force Update Interval (seconds)"
msgstr "强制更新间隔（秒）"

msgid "Manual Update"
msgstr "手动更新"

msgid "Update Now"
msgstr "立即更新"

msgid "MiniGate - SSL Certificate"
msgstr "MiniGate - SSL 证书"

msgid "Automatic SSL/TLS certificate management via ACME (Let's Encrypt). Uses Cloudflare DNS-01 challenge for verification."
msgstr "通过 ACME（Let's Encrypt）自动管理 SSL/TLS 证书。使用 Cloudflare DNS-01 验证方式。"

msgid "ACME Settings"
msgstr "ACME 设置"

msgid "Enable ACME"
msgstr "启用 ACME"

msgid "Account Email"
msgstr "账户邮箱"

msgid "Optional. Used for expiration reminders from Let's Encrypt."
msgstr "可选。Let's Encrypt 会在证书即将过期时发送提醒邮件。"

msgid "Enter your API Token (needs Zone:DNS:Edit permission)"
msgstr "输入你的 API 令牌（需要 Zone:DNS:Edit 权限）"

msgid "Create a token at Cloudflare Dashboard → My Profile → API Tokens"
msgstr "在 Cloudflare 控制台 → 我的个人资料 → API 令牌 处创建"

msgid "Key Type"
msgstr "密钥类型"

msgid "Staging Mode"
msgstr "测试模式"

msgid "Use Let's Encrypt staging server for testing. Disable for production certificates."
msgstr "使用 Let's Encrypt 测试服务器。正式使用时请关闭此选项。"

msgid "Renew Before (days)"
msgstr "提前续期天数"

msgid "Renew certificate when less than this many days remain."
msgstr "证书剩余天数少于此值时自动续期。"

msgid "Certificates"
msgstr "证书列表"

msgid "Issued certificates and their status."
msgstr "已签发的证书及其状态。"

msgid "Actions"
msgstr "操作"

msgid "Issue Certificate"
msgstr "签发证书"

msgid "Issue / Renew Now"
msgstr "立即签发 / 续期"

msgid "Install acme.sh"
msgstr "安装 acme.sh"

msgid "Download & Install"
msgstr "下载并安装"

msgid "MiniGate - Reverse Proxy"
msgstr "MiniGate - 反向代理"

msgid "Configure reverse proxy rules. Each entry creates an Nginx server block with SSL termination."
msgstr "配置反向代理规则。每条规则会生成一个带 SSL 终结的 Nginx 站点配置。"

msgid "Proxy Rules"
msgstr "代理规则"

msgid "Enable"
msgstr "启用"

msgid "Name"
msgstr "名称"

msgid "Listen Port"
msgstr "监听端口"

msgid "Target Address"
msgstr "目标地址"

msgid "Target Port"
msgstr "目标端口"

