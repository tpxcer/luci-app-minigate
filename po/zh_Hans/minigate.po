msgid "recommended"
msgstr "推荐"

msgid "Staging mode"
msgstr "测试模式"

msgid "Disable for production use."
msgstr "正式使用请关闭。"

msgid "Issued certificates"
msgstr "已签发证书"

msgid "acme.sh status"
msgstr "acme.sh 状态"

msgid "Actions"
msgstr "操作"

