msgid "MiniGate"
msgstr "MiniGate 轻网关"

msgid "Lightweight gateway management: DDNS, ACME SSL certificates, and reverse proxy for OpenWrt."
msgstr "轻量级网关管理：动态域名解析、ACME SSL 证书签发、反向代理，专为 OpenWrt 设计。"

msgid "Service Status"
msgstr "服务状态"

msgid "Overview"
msgstr "总览"

msgid "Global Settings"
msgstr "全局设置"

msgid "Enable MiniGate"
msgstr "启用 MiniGate"

msgid "General"
msgstr "总览"

