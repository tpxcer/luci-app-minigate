msgstr "证书路径"

msgid "Expiry"
msgstr "过期时间"

msgid "Status"
msgstr "状态"

msgid "Valid"
msgstr "有效"

msgid "No certificates issued yet. Configure ACME settings and click \"Issue / Renew Now\"."
msgstr "尚未签发任何证书。请先配置 ACME 设置，然后点击「立即签发 / 续期」。"

